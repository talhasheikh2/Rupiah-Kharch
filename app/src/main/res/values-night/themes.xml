<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.RupiahKharch" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Disables the system preview window on older Android versions -->
        <item name="android:windowDisablePreview">true</item>

        <!-- Matches the background of your custom splash -->
        <item name="android:windowBackground">@drawable/splash_gradient</item>

        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="28">shortEdges</item>

        <!-- Sets the system splash icon to transparent for Android 12+ -->
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@android:color/transparent</item>
    </style>

    <style name="Theme.RupiahKharch" parent="Base.Theme.RupiahKharch" />
</resources>