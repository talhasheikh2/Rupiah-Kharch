<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="75dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <View
            android:id="@+id/viewIndicator"
            android:layout_width="12dp"
            android:layout_height="match_parent"
            android:background="#FF5252" />
        <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="12dp">

        <View
            android:id="@+id/iconContainer"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:padding="10dp"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_record_icon"
            android:backgroundTint="#FFF1F1" />

        <ImageView
            android:id="@+id/ivRecordIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignStart="@id/iconContainer"
            android:layout_alignEnd="@id/iconContainer"
            android:layout_alignTop="@id/iconContainer"
            android:layout_alignBottom="@id/iconContainer"
            android:src="@drawable/fastfood"
            app:tint="#FF5252" />

        <TextView
            android:id="@+id/tvRecordTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/iconContainer"
            android:text="Food"
            android:textColor="#2D3436"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRecordAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="+$30"
            android:textColor="#4CAF50"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>